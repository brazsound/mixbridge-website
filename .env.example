# Supabase (for magic link auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
#
# Magic links: In Supabase Dashboard → Authentication → URL Configuration:
# - Site URL = your production origin (e.g. https://www.mixbridge.net)
# - Redirect URLs must include https://www.mixbridge.net/account (and /account/** if offered)
# If Site URL is still http://localhost:3000, emails will open localhost and sign-in will fail.

# License API (backend URL - e.g. Vercel deployment)
VITE_LICENSE_API_URL=https://your-backend.vercel.app

# Comma-separated list of admin emails (shows Admin nav link + grants access to /admin)
# Must match ADMIN_EMAILS in the backend environment
VITE_ADMIN_EMAILS=you@example.com
#
# Supabase → Authentication → Providers → Email: enable "Email" and allow passwords
# (sign up / sign in). Add https://www.your-domain.com/account to Redirect URLs for
# magic link, email change, and password reset.
